/* ==========================================================================
   motion-card 通用动效预览组件
   - 演示舞台 (mc__stage / phone / viewport)
   - 简化手机壳: 圆角矩形外壳 + 8rpx 均匀黑边框 + 4 侧边键 (mc__btn-*)
   - 6 个场景的 demo 元素基础样式 (mc__modal / mc__sheet / ...)
   - 6 个 skill 的 keyframes (mc-anim-<skill-id>) — 文件末尾自动生成段
   - 控件 (重播/倍速) 由外部页面 (detail.wxss .dt__controls) 提供并调用 setSpeed()/replay()
   ========================================================================== */

/* ====== 舞台 ====== */
.mc {
  display: flex; flex-direction: column;
  align-items: center;
  /* background/border-radius 由外部容器(detail.wxss .dt__stage)决定,组件本身保持透明
     底 padding 0: 让手机壳底直接贴 motion-card 容器底 (与 .dt__stage padding-bottom: 0 配合, 控件区紧凑) */
  padding: 8rpx 0 0;
}
.mc__stage {
  display: flex; justify-content: center;
  width: 100%;
  padding: 24rpx 0 0;
}
/* 简化手机壳: 440x880rpx (~9:18), 黑色 12rpx 均匀边框 + 大圆角同心 + 4 侧边键
   不再做 Notch/Home Indicator 等细节区分, 保留纯净的圆角矩形 + 侧键 */
.mc__phone {
  position: relative;
  width: 440rpx;
  height: 880rpx;
  background: #1a1a1a;
  border-radius: 60rpx;
  box-sizing: border-box;
}
/* 屏幕区域: absolute 四边均 12rpx 黑色边框, 内圆角 48rpx 与外圆角 60rpx 同心 (60 - 12 = 48) */
.mc__viewport {
  position: absolute;
  top: 12rpx;
  bottom: 12rpx;
  left: 12rpx;
  right: 12rpx;
  background: #ededed;
  border-radius: 48rpx;
  overflow: hidden;
}
/* ====== 侧边按键 (深灰金属条, 略凸出 phone 边框 -3rpx) ====== */
.mc__btn-mute,
.mc__btn-vol-up,
.mc__btn-vol-down {
  position: absolute;
  left: -3rpx;
  width: 6rpx;
  background: #2a2a2a;
  border-radius: 2rpx 0 0 2rpx;
}
.mc__btn-mute     { top: 140rpx; height: 32rpx; }
.mc__btn-vol-up   { top: 200rpx; height: 70rpx; }
.mc__btn-vol-down { top: 290rpx; height: 70rpx; }
.mc__btn-power {
  position: absolute;
  right: -3rpx;
  top: 220rpx;
  width: 6rpx;
  height: 96rpx;
  background: #2a2a2a;
  border-radius: 0 2rpx 2rpx 0;
}
.mc__bg-content {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  color: #b0b0b8; font-size: 22rpx;
}

/* ====== C1 Modal ====== */
/* 遮罩 fade-in 动画: opacity 0→1, duration 由 wxml inline style 注入 (与 sheet/modal 同步, 倍速切换不掉拍);
   用 Material standard easing (不用 elegant 微超越曲线): 遮罩不需要弹跳, 平滑渐显才是正确语义;
   修复"遮罩瞬间出现, sheet/modal 慢慢入场"的节奏不同步("闪一下")问题。
   200ms 仅作 fallback (= catalog.js 中 orchestration.maskDuration 默认值);
   实际运行时 wxml inline style 总会覆盖此值, 此 200ms 仅在 inline style 缺失时兜底 */
.mc__mask {
  position: absolute; inset: 0;
  background: rgba(0, 0, 0, .4);
  animation: mc-mask-fade-in 200ms cubic-bezier(0.4, 0, 0.2, 1) both;
}
@keyframes mc-mask-fade-in {
  0%   { opacity: 0; }
  100% { opacity: 1; }
}
/* C1 Modal: 纯白卡片, 无子元素, 仅演示"上滑浮入 + 过冲"动效;
   height 140rpx 跟原带文字版本视觉高度一致 (24+28+12+26+24 ≈ 114rpx 含 padding, 取 140rpx 略宽松) */
.mc__modal {
  position: absolute; left: 50%; top: 50%;
  width: 320rpx;
  height: 140rpx;
  background: #fff; border-radius: 12rpx;
  box-sizing: border-box;
  transform: translate3d(-50%, -50%, 0);
  will-change: transform, opacity;
}

/* ====== C2 ActionSheet (纯白卡片, 无子元素, 仅演示"上滑出现"动效) ======
   - 移除原 4 个 .mc__sheet-item 和分隔线, 卡片高度由显式 height: 50% 撑出 (= viewport 半屏) */
.mc__sheet {
  position: absolute; left: 0; right: 0; bottom: 0;
  height: 50%;
  background: #fff;
  border-radius: 12rpx 12rpx 0 0;
  will-change: transform;
}

/* ====== C3 Toast ====== */
/* top: 18rpx 在 viewport 内上方, viewport 起点距 phone 顶 12rpx, 所以 toast 距 phone 顶 = 30rpx */
.mc__toast {
  position: absolute; top: 18rpx; left: 50%;
  padding: 10rpx 18rpx;
  background: rgba(0, 0, 0, .8); color: #fff;
  border-radius: 6rpx;
  font-size: 20rpx;
  white-space: nowrap;
  transform: translate3d(-50%, 0, 0);
  will-change: transform, opacity;
}

/* ====== C4 Card list (两列瀑布流, 6 卡 stagger 入场) ======
   - 顶距 240rpx (用户指定的视觉留白, 在 viewport 内从顶部预留)
   - 左右各 24rpx 边距, 列间距 16rpx, 卡间距 16rpx
   - 高度错落: tall 180rpx / short 120rpx (左列高/矮/高, 右列矮/高/矮)
   - 纯白卡 #fff, 圆角 12rpx, 无装饰元素 (无 border / 无内部线条) */
.mc__cardlist {
  position: absolute;
  inset: 0;
  padding: 240rpx 24rpx 0;
  box-sizing: border-box;
  display: flex;
  gap: 16rpx;
}
.mc__cardlist-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.mc__card {
  background: #fff;
  border-radius: 12rpx;
  will-change: transform, opacity;
}
/* 高度 +50% (从原 180/120 → 270/180): 6 卡 + 240rpx 顶距下,
   左列高度 752rpx > viewport 可用 616rpx, 底部 tall 卡会被 overflow:hidden 自然裁切;
   这是有意为之的"往下还有内容"瀑布流眼动效果, 营造列表可继续滚动的暗示 */
.mc__card--tall  { height: 270rpx; }
.mc__card--short { height: 180rpx; }

/* ====== C5 Popover ====== */
/* anchor (48rpx 高) top: 280rpx → 底缘 328rpx; popover top: 340rpx, 留 12rpx gap 给箭头 */
.mc__anchor {
  position: absolute; top: 280rpx; left: 50%;
  transform: translateX(-50%);
  width: 48rpx; height: 48rpx;
  background: #1a1a1a; color: #fff;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx;
}
.mc__popover {
  position: absolute; top: 340rpx; left: 50%;
  transform-origin: center top;
  background: #fff;
  padding: 12rpx 18rpx;
  border-radius: 10rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, .12);
  font-size: 20rpx;
  margin-left: -100rpx;
  width: 200rpx;
  box-sizing: border-box;
  text-align: center;
  will-change: transform, opacity;
}
.mc__popover-arrow {
  position: absolute; top: -8rpx; left: 50%;
  width: 0; height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-bottom: 8rpx solid #fff;
  transform: translateX(-50%);
}

/* ====== C10 Refresh ====== */
.mc__refresh {
  display: flex; justify-content: center; gap: 10rpx;
  height: 60rpx; align-items: center;
  background: rgba(0, 0, 0, .04);
  will-change: transform, opacity;
}
.mc__refresh-dot {
  width: 10rpx; height: 10rpx;
  background: #888; border-radius: 50%;
}

/* ========== 自动生成段: skill keyframes (由 scripts/gen_keyframes.py 自动生成,勿手动改) ====== */

@keyframes mc-modal-slide-up-in-elegant {
  0%   { transform: translate3d(-50%, calc(-50% + 24rpx), 0); opacity: 0; }
  60%  { transform: translate3d(-50%, calc(-50% - 8rpx), 0); opacity: 1; }
  100% { transform: translate3d(-50%, -50%, 0); opacity: 1; }
}
.mc-anim-modal-slide-up-in-elegant {
  animation: mc-modal-slide-up-in-elegant 480ms cubic-bezier(0.4, 0, 0.2, 1) both;
}

@keyframes mc-actionsheet-slide-up-elegant {
  0%   { transform: translate3d(0, 100%, 0); }
  100% { transform: translate3d(0, 0, 0); }
}
.mc-anim-actionsheet-slide-up-elegant {
  animation: mc-actionsheet-slide-up-elegant 420ms cubic-bezier(0.32, 1.18, 0.5, 1) both;
}

@keyframes mc-toast-drop-in-elegant {
  0%   { transform: translate3d(-50%, -200%, 0); opacity: 0; }
  100% { transform: translate3d(-50%, 0, 0); opacity: 1; }
}
.mc-anim-toast-drop-in-elegant {
  animation: mc-toast-drop-in-elegant 520ms cubic-bezier(0.32, 1.18, 0.5, 1) both;
}

@keyframes mc-card-stagger-in-elegant {
  0%   { transform: translate3d(0, 24rpx, 0); opacity: 0; }
  100% { transform: translate3d(0, 0, 0); opacity: 1; }
}
.mc-anim-card-stagger-in-elegant {
  animation: mc-card-stagger-in-elegant 600ms cubic-bezier(0.32, 1.18, 0.5, 1) both;
}

@keyframes mc-popover-anchor-in-elegant {
  0%   { transform: scale(0.6); opacity: 0; }
  100% { transform: scale(1.0); opacity: 1; }
}
.mc-anim-popover-anchor-in-elegant {
  animation: mc-popover-anchor-in-elegant 520ms cubic-bezier(0.32, 1.18, 0.5, 1) both;
}

@keyframes mc-refresh-pull-in-elegant {
  0%   { transform: translate3d(0, -100%, 0); opacity: 0; }
  100% { transform: translate3d(0, 0, 0); opacity: 1; }
}
.mc-anim-refresh-pull-in-elegant {
  animation: mc-refresh-pull-in-elegant 520ms cubic-bezier(0.32, 1.18, 0.5, 1) both;
}

