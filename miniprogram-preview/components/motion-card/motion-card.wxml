<view class="mc" wx:if="{{skill}}">
  <view class="mc__stage">
    <view class="mc__phone">
      <!-- 侧边按键 (左 3: 静音/音量+/音量-, 右 1: 电源) -->
      <view class="mc__btn-mute"></view>
      <view class="mc__btn-vol-up"></view>
      <view class="mc__btn-vol-down"></view>
      <view class="mc__btn-power"></view>
      <view class="mc__viewport">

        <!-- C1 Modal: 居中弹窗 (组合动画 orchestration + 显式过冲, 跟 C2 共享 mask/mainDelay)
             actualMaskDuration: 200ms × 倍速 (skill.orchestration.maskDuration)
             actualMainDelay:    180ms × 倍速 (skill.orchestration.mainDelay = 0.9 × maskDuration)
             actualDuration:     480ms × 倍速 (modal 自身: 上滑 + 60% 过冲 -8rpx + 回正)
             curve override:     ease-in-out (cubic-bezier(0.4, 0, 0.2, 1)), 不带隐式 overshoot
             1x 总时长 = 0.9 × 200 + 480 = 660ms (modal 自身 480ms ≤ 1000ms) -->
        <block wx:if="{{skill.sceneId === 'C1'}}">
          <view wx:if="{{visible}}" class="mc__mask"
                style="animation-duration: {{actualMaskDuration}}ms;"></view>
          <view wx:if="{{visible}}"
                class="mc__modal mc-anim-{{skill.id}}"
                style="animation-duration: {{actualDuration}}ms; animation-delay: {{actualMainDelay}}ms;"></view>
        </block>

        <!-- C2 ActionSheet: 底部抽屉 (纯白卡片, 组合动画 orchestration, 跟 C1 共享 mask/mainDelay)
             actualMaskDuration: 200ms × 倍速 (skill.orchestration.maskDuration)
             actualMainDelay:    180ms × 倍速 (skill.orchestration.mainDelay = 0.9 × maskDuration)
             actualDuration:     420ms × 倍速 (sheet 自身, override 自 ELEGANT_DURATION 520)
             curve:              ELEGANT_CURVE (cubic-bezier(0.32, 1.18, 0.5, 1)) - 跟 C1 不同
             1x 总时长 = 0.9 × 200 + 420 = 600ms (比 C1 660ms 略短, 节奏更平滑) -->
        <block wx:elif="{{skill.sceneId === 'C2'}}">
          <view wx:if="{{visible}}" class="mc__mask"
                style="animation-duration: {{actualMaskDuration}}ms;"></view>
          <view wx:if="{{visible}}"
                class="mc__sheet mc-anim-{{skill.id}}"
                style="animation-duration: {{actualDuration}}ms; animation-delay: {{actualMainDelay}}ms;"></view>
        </block>

        <!-- C3 Toast: 顶部提示 -->
        <block wx:elif="{{skill.sceneId === 'C3'}}">
          <view wx:if="{{visible}}"
                class="mc__toast mc-anim-{{skill.id}}"
                style="animation-duration: {{actualDuration}}ms;">
            <text>操作成功</text>
          </view>
        </block>

        <!-- C4 Card list: 列表项卡片 (两列瀑布流, 6 卡 stagger Z 字扫描)
             顶距 240rpx, 左右各 24rpx, 列间距 16rpx, 卡间距 16rpx
             高度错落: 左列 高/矮/高, 右列 矮/高/矮; 纯白卡 #fff, 无装饰元素
             stagger Z 字顺序 (从上到下逐行扫描):
               左1=0ms / 右1=60ms (第一行)
               左2=120ms / 右2=180ms (第二行)
               左3=240ms / 右3=300ms (第三行)
             单卡 600ms (override, 见 catalog.js), 总入场 = 600+300 = 900ms (单卡仍合规 ≤ 1000ms) -->
        <block wx:elif="{{skill.sceneId === 'C4'}}">
          <view class="mc__cardlist">
            <view class="mc__cardlist-col">
              <view wx:if="{{visible}}" class="mc__card mc__card--tall mc-anim-{{skill.id}}"
                    style="animation-duration: {{actualDuration}}ms; animation-delay: 0ms;"></view>
              <view wx:if="{{visible}}" class="mc__card mc__card--short mc-anim-{{skill.id}}"
                    style="animation-duration: {{actualDuration}}ms; animation-delay: 120ms;"></view>
              <view wx:if="{{visible}}" class="mc__card mc__card--tall mc-anim-{{skill.id}}"
                    style="animation-duration: {{actualDuration}}ms; animation-delay: 240ms;"></view>
            </view>
            <view class="mc__cardlist-col">
              <view wx:if="{{visible}}" class="mc__card mc__card--short mc-anim-{{skill.id}}"
                    style="animation-duration: {{actualDuration}}ms; animation-delay: 60ms;"></view>
              <view wx:if="{{visible}}" class="mc__card mc__card--tall mc-anim-{{skill.id}}"
                    style="animation-duration: {{actualDuration}}ms; animation-delay: 180ms;"></view>
              <view wx:if="{{visible}}" class="mc__card mc__card--short mc-anim-{{skill.id}}"
                    style="animation-duration: {{actualDuration}}ms; animation-delay: 300ms;"></view>
            </view>
          </view>
        </block>

        <!-- C5 Popover: 浮层 -->
        <block wx:elif="{{skill.sceneId === 'C5'}}">
          <view class="mc__anchor">⌘</view>
          <view wx:if="{{visible}}"
                class="mc__popover mc-anim-{{skill.id}}"
                style="animation-duration: {{actualDuration}}ms;">
            <view class="mc__popover-arrow"></view>
            <view>这是引导提示</view>
          </view>
        </block>

        <!-- C10 Refresh pull -->
        <block wx:elif="{{skill.sceneId === 'C10'}}">
          <view wx:if="{{visible}}"
                class="mc__refresh mc-anim-{{skill.id}}"
                style="animation-duration: {{actualDuration}}ms;">
            <view class="mc__refresh-dot"></view>
            <view class="mc__refresh-dot"></view>
            <view class="mc__refresh-dot"></view>
          </view>
          <view class="mc__bg-content">下拉刷新触发后的指示器</view>
        </block>

      </view>
    </view>
  </view>
</view>
