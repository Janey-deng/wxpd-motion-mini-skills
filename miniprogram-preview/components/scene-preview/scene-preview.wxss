/* ==========================================================================
   scene-preview - 6 个动效场景的 mini 静态终态示意图
   - 不带任何动画;只展示该场景"动效完成后"的视觉形态
   - 1:1 正方形容器, 三层结构 (与详情页 motion-card 同色, 但比例更夸张):
       prv__phone   (深灰舞台 #cfcfd2, 等同 detail.dt__stage, overflow hidden 裁切手机壳底部)
       prv__shell   (黑色手机外壳, 顶部进入 + 底部溢出灰底被裁切, 仅露出"上半身")
       prv__viewport(浅灰屏幕, 在 shell 内边距处定位, 顶圆底直贴 phone 底, 容纳场景元素)
   - shell 与 viewport 是兄弟节点 (而非嵌套), 各自 absolute 独立定位:
       shell 提供"手机外壳"的视觉黑边框 (顶+左右+大圆角)
       viewport 后绘制盖在 shell 之上, 提供屏幕显示区域
   - 外层卡片 (.idx__cell-prv) 用 border-radius 做顶部圆角裁切, 组件自身不画边框
   ========================================================================== */

/* prv 容器宽度由父级决定 (100%);用 padding-bottom: 100% 维持 1:1 正方形 */
.prv {
  width: 100%;
  position: relative;
  padding-bottom: 100%;
}
/* 灰底舞台: 与详情页 .dt__stage 同色; overflow hidden 用于裁切手机壳底部溢出部分 */
.prv__phone {
  position: absolute;
  inset: 0;
  background: #cfcfd2;
  overflow: hidden;
}
/* 黑色手机外壳: 顶部 / 左右四周均留 14% 灰边 (1:1 正方形下 top 与 left/right 视觉等距),
   底部溢出 phone 高度的 40% 被裁; 纯视觉元素, 不含内容;
   viewport 后绘制盖在其上, 留下黑色边框作为"手机壳"轮廓 */
.prv__shell {
  position: absolute;
  top: 14%;
  left: 14%;
  right: 14%;
  bottom: -40%;
  background: #1a1a1a;
  border-radius: 32rpx;
  pointer-events: none;
}
/* 屏幕区域: 在 shell 内边距处定位 (top/左右各在 shell 基础上 +8rpx),
   顶圆 (与 shell 协调) 底直 (贴 phone 底, 让 shell 底部裁切看不出突兀);
   场景内容在此 viewport 内以 % / rpx 定位 */
.prv__viewport {
  position: absolute;
  top: calc(14% + 8rpx);
  left: calc(14% + 8rpx);
  right: calc(14% + 8rpx);
  bottom: 0;
  background: #ededed;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

/* 通用 */
.prv__bg {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  color: #c0c0c8; font-size: 16rpx;
}
.prv__bg--below {
  top: 40rpx;
}
.prv__mask {
  position: absolute; inset: 0;
  background: rgba(0, 0, 0, .35);
}

/* C1 Modal (纯白卡片, 无子元素, 与详情页 motion-card 同步)
   aspect-ratio 16:7 跟详情页 .mc__modal (320×140rpx) 比例一致, 自适应 viewport 宽度 */
.prv__modal {
  position: absolute; left: 50%; top: 50%;
  transform: translate(-50%, -50%);
  width: 70%;
  aspect-ratio: 16 / 7;
  background: #fff; border-radius: 8rpx;
}

/* C2 Sheet (纯白卡片, 无子元素, 与详情页 motion-card 同步) */
.prv__sheet {
  position: absolute; left: 0; right: 0; bottom: 0;
  height: 50%;
  background: #fff;
  border-radius: 12rpx 12rpx 0 0;
}

/* C3 Toast */
.prv__toast {
  position: absolute; top: 14rpx; left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, .75); color: #fff;
  font-size: 14rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  white-space: nowrap;
}

/* C4 Card list (两列瀑布流, 高度错落; 与详情页 motion-card 视觉比例对齐)
   - 纯白卡, 无 border / 无装饰; 与 viewport 浅灰底 #ededed 形成微反差
   - 顶距 80rpx: 按详情页 240/856 ≈ 28% 比例反推 (缩略图 viewport 高 ~284rpx × 28% ≈ 80rpx)
   - 边距 14rpx + 卡/列间距 10rpx: 按详情页 24rpx 边距 / 16rpx gap (≈ 列宽 13.6% / 9.1%)
     反推到缩略图列宽 ~103rpx, 跟详情页"宽松感"对齐, 不再拥挤 */
.prv__cardlist {
  position: absolute; inset: 0;
  padding: 80rpx 14rpx 0;
  box-sizing: border-box;
  display: flex; gap: 10rpx;
}
.prv__cardlist-col {
  flex: 1;
  display: flex; flex-direction: column; gap: 10rpx;
}
.prv__card {
  background: #fff;
  border-radius: 4rpx;
}
/* 卡片高度在原"按详情页比例反推"基础上再 +30%:
   - 原值: tall 158 / short 105 (= 详情页 270:176 / 180:176 比例反推)
   - 现值: tall 158×1.3 ≈ 205, short 105×1.3 ≈ 137
   - 视觉效果: 卡片更扎实, 第一行卡占满 viewport 可见区, 第二行/第三行被 overflow:hidden 几乎完全裁切,
     形成"只见首行卡 + 底部强烈瀑布流暗示"的极简预览效果 */
.prv__card--tall  { height: 205rpx; }
.prv__card--short { height: 137rpx; }

/* C5 Popover */
.prv__anchor {
  position: absolute; top: 100rpx; left: 50%;
  transform: translateX(-50%);
  width: 24rpx; height: 24rpx;
  background: #1a1a1a;
  border-radius: 50%;
}
.prv__popover {
  position: absolute; top: 138rpx; left: 50%;
  transform: translateX(-50%);
  background: #fff;
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
  font-size: 14rpx;
  color: #333;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, .1);
  white-space: nowrap;
}

/* C10 Refresh */
.prv__refresh {
  display: flex; justify-content: center; gap: 8rpx;
  height: 32rpx; align-items: center;
  background: rgba(0, 0, 0, .04);
}
.prv__dot {
  width: 8rpx; height: 8rpx;
  background: #888;
  border-radius: 50%;
}
