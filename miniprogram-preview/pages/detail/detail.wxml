<view wx:if="{{skill}}" class="dt">

  <!-- 导航条背景层: 默认透明; 页面滚动时切 #fff, 区分导航区与下方正文区
       z-index 50 (低于 .dt__back 100, 让返回按钮始终在上); pointer-events: none 不拦截点击 -->
  <view
    class="dt__navbg {{navSolid ? 'dt__navbg--solid' : ''}}"
    style="height: {{safeTop}}px;"
  ></view>

  <!-- 自造返回按钮 (custom 模式下高仿微信原生 default 返回组件)
       - position: fixed 永远在屏顶, 跟原生导航栏行为一致
       - top / width / height 由 inline 注入, 严格跟微信胶囊按钮垂直对齐 + 同高
       - 半透明白圆 + 黑色箭头, 灰底 / 滚动后白底场景下都清晰可见
       说明: 微信 <navigation-bar> 内置组件不提供 back 按钮, custom 模式下
             官方就没有"原生返回组件", 自造是 custom 模式的标准做法 -->
  <view
    class="dt__back"
    style="top: {{backTop}}px; width: {{backHeight}}px; height: {{backHeight}}px;"
    bindtap="goBack"
  >
    <text class="dt__back-icon">‹</text>
  </view>

  <!-- 通栏预览舞台 (灰底从屏顶贯通到状态栏 + 胶囊按钮区域) -->
  <view class="dt__stage" style="padding-top: {{safeTop}}px;">
    <motion-card
      id="mc"
      skill-id="{{skillId}}"
      auto-play="{{true}}"
    ></motion-card>
  </view>

  <!-- 内容区 wrapper: 顶部圆角 32rpx + 上推 -32rpx 让圆角覆盖在 .dt__stage 深灰底上, 形成"内容区从舞台下方上滑"视觉
       padding-top: 32rpx 抵消 margin-top: -32rpx, 内部 controls/head/section 的 margin-top 完全保持原间距 -->
  <view class="dt__body">

  <!-- 控件区 (倍速 + 重播, 无背景, 直接排在预览图下方)
       左侧 dt__speed: 0.2x / 1x 两档 (去掉 0.5x 中间档, 让用户体感差异更明显);
       右侧 dt__btn-replay: 跟 dt__speed-item 等宽 (120rpx) 视觉对称 -->
  <view class="dt__controls">
    <view class="dt__speed">
      <view class="dt__speed-item {{currentSpeed === 0.2 ? 'dt__speed-item--active' : ''}}"
            data-speed="0.2" bindtap="onSpeedTap">0.2x</view>
      <view class="dt__speed-item {{currentSpeed === 1 ? 'dt__speed-item--active' : ''}}"
            data-speed="1" bindtap="onSpeedTap">1x</view>
    </view>
    <view class="dt__btn-replay" bindtap="onReplay">↻ 重播</view>
  </view>

  <view class="dt__head">
    <view class="dt__name">{{skill.name}}</view>
    <view class="dt__physics">{{skill.physics}}</view>
  </view>

  <view class="dt__section">
    <view class="dt__section-title">AI 唤醒词</view>
    <view class="dt__table">
      <view class="dt__row">
        <text class="dt__row-key">中文</text>
        <text class="dt__row-val">{{skill.wakeupCN}}</text>
      </view>
      <view class="dt__row">
        <text class="dt__row-key">英文</text>
        <text class="dt__row-val ml-mono">{{skill.wakeupEN}}</text>
      </view>
    </view>
  </view>

  <view class="dt__section">
    <view class="dt__section-title">物理参数</view>
    <view class="dt__table">
      <view class="dt__row">
        <text class="dt__row-key">Duration</text>
        <text class="dt__row-val ml-mono">{{skill.duration}}ms</text>
      </view>
      <view class="dt__row">
        <text class="dt__row-key">Curve</text>
        <text class="dt__row-val ml-mono">{{skill.curve}}</text>
      </view>
      <view class="dt__row">
        <text class="dt__row-key">Properties</text>
        <text class="dt__row-val ml-mono">transform, opacity</text>
      </view>
    </view>
  </view>

  <view class="dt__section">
    <view class="dt__section-title">自查报告</view>
    <view class="dt__check">
      <view class="dt__check-item">
        <text class="dt__check-icon">✓</text>
        <text>FPS 预估: 60+ (transform/opacity GPU 合成)</text>
      </view>
      <view class="dt__check-item">
        <text class="dt__check-icon">✓</text>
        <text>重排风险: 无 (未触发 layout 属性)</text>
      </view>
      <view class="dt__check-item">
        <text class="dt__check-icon">✓</text>
        <text>合成层: 已触发 GPU 加速 (translate3d + will-change)</text>
      </view>
      <view class="dt__check-item">
        <text class="dt__check-icon">✓</text>
        <text>时长合规: {{skill.duration}}ms ≤ 600ms</text>
      </view>
    </view>
  </view>

  <view class="dt__actions">
    <view class="dt__btn" bindtap="copyCurve">复制 CSS 片段</view>
    <view class="dt__btn dt__btn--ghost" bindtap="copySkillRef">复制 Cursor Prompt</view>
  </view>

  <view class="dt__footer">
    <text class="dt__footer-line ml-mono">docs/skills/{{skill.id}}.md</text>
    <text class="dt__footer-line">完整代码与适用边界请查阅 md 文件</text>
  </view>

  </view>
  <!-- /dt__body -->

</view>
