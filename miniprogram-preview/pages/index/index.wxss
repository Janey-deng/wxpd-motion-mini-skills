.idx {
  /* padding-top 由 wxml 内联 style 动态注入 (= 胶囊按钮底部 + 6px),避免标题被遮挡 */
  padding: 0 0 64rpx;
}

/* ====== 导航条背景层 (默认透明, 滚动后 #fff) ====== */
.idx__navbg {
  position: fixed;
  top: 0; left: 0; right: 0;
  /* height 由 wxml inline style 注入 (= safeTop = menu.bottom + 6) */
  background: transparent;
  transition: background 200ms cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 50;
  pointer-events: none;
}
.idx__navbg--solid {
  background: #ffffff;
}

.idx__hero {
  padding: 16rpx 32rpx 24rpx;
}
.idx__title {
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: -1rpx;
}
.idx__subtitle {
  font-size: 26rpx;
  color: #888;
  margin-top: 8rpx;
}

/* ====== 两列等宽对齐卡片(上图下文) ====== */
.idx__grid {
  /* CSS Grid 实现两列严格对齐: 每行两卡顶部对齐, 行内最高的卡决定行高 (column-count 瀑布流不保证对齐, 真机渲染易错位) */
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 0 24rpx;
}
.idx__cell {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: transform 200ms cubic-bezier(0.4, 0, 0.2, 1);
}
.idx__cell:active {
  transform: scale(0.98);
}
.idx__cell-prv {
  width: 100%;
  /* 与卡片顶部圆角(20rpx)对齐;底部接文字区, 直角即可。
     overflow: hidden 由父级 .idx__cell 统一承担, 这里无需重复 */
  border-radius: 20rpx 20rpx 0 0;
}
.idx__cell-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 16rpx;
}
/* sceneId tag: 灰色 mono 小字, 跟 .idx__cell-dur 同色同号同字族, 形成"标题上下灰色 metadata"视觉对称 */
.idx__cell-id {
  font-size: 20rpx;
  color: #b0b0b8;
  letter-spacing: 0.5rpx;
}
.idx__cell-name {
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.35;
  color: #1a1a1a;
  word-break: break-all;
}
.idx__cell-dur {
  font-size: 20rpx;
  color: #b0b0b8;
}

.idx__footer {
  margin-top: 48rpx;
  padding: 32rpx;
  text-align: center;
}
.idx__footer-line {
  display: block;
  font-size: 22rpx;
  color: #b0b0b8;
  margin-bottom: 8rpx;
}
.idx__footer-line--mono {
  color: #d0d0d4;
}
